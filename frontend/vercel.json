{
  "rewrites": [
    { "source": "/((?!assets/|cafe/|clubs/|iro/|library/|favicon.svg|icons.svg).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
